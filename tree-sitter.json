{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "zscript",
      "camelcase": "ZScript",
      "title": "ZScript",
      "scope": "source.zscript",
      "file-types": [
        "zsc",
        "zs"
      ],
      "injection-regex": "^zscript$",
      "class-name": "TreeSitterZscript"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "ZScript (UZDoom) language support",
    "authors": [
      {
        "name": "danatationn",
        "email": "lemontasteicetea@proton.me",
        "url": "https://danatationn.github.io"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-zscript",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
